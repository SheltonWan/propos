# PropOS 部署凭据模板
# 使用方法：复制本文件为 .deploy.env 并填写实际值
#   cp .deploy.env.example .deploy.env
# 注意：.deploy.env 已加入 .gitignore，切勿提交到版本控制

# ============================================================
# 腾讯云 TCR 镜像仓库凭据
# 用于：
#   - 本地 docker push（backend/deploy.sh 自动登录）
#   - 服务器 docker pull（setup_server.sh 自动配置服务器端登录）
# 获取方式：腾讯云控制台 → 容器镜像服务 → 个人版 → 访问凭证
# ============================================================
# ============================================================
# 目标服务器地址
# ============================================================
SERVER_HOST=your_server_public_ip

# ============================================================
# 服务器 SSH 密码（仅用于首次 ssh-copy-id 推送公钥，之后永久免密可留空）
# 需要本地安装 sshpass：brew install hudochenkov/sshpass/sshpass
# 公钥推送成功后可删除此行或清空，不影响后续部署
# ============================================================
SERVER_SSH_PASSWORD=your_server_root_password

# ============================================================
# 腾讯云 TCR 镜像仓库凭据
# ============================================================
TCR_REGISTRY=ccr.ccs.tencentyun.com
TCR_USER=your_account_id
TCR_PASSWORD=your_access_token_or_password

# ============================================================
# SMTP 邮件服务（本地与服务器统一使用相同配置）
# ============================================================
SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=your_smtp_from

# ============================================================
# 超级管理员初始账号（仅 setup_server.sh 首次初始化时使用）
# ADMIN_PASSWORD_HASH 为 bcrypt hash（cost≥12），禁止存储明文密码
# 生成命令（需安装 apache2-utils / httpd-tools）：
#   htpasswd -bnBC 12 '' 'YourPassword' | tr -d ':\n' | sed 's/\$2y/\$2a/'
# 或使用 Python：
#   python3 -c "import bcrypt; print(bcrypt.hashpw(b'YourPassword', bcrypt.gensalt(12)).decode())"
# 留空则 setup_server.sh 使用开发默认密码（ChangeMe@2026!），生产环境必须替换
# ============================================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=
