{
  "name": "propos-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:h5": "uni",
    "dev:mp-weixin": "uni -p mp-weixin",
    "dev:app-plus": "uni -p app-plus",
    "dev:mp-harmony": "uni -p mp-harmony",
    "build:h5": "uni build",
    "build:mp-weixin": "uni build -p mp-weixin",
    "build:app-plus": "uni build -p app-plus",
    "build:mp-harmony": "uni build -p mp-harmony",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:theme": "node ./scripts/validate-theme-usage.mjs",
    "format": "prettier --write \"src/**/*.{ts,vue,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,scss,json}\"",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-5000720260410001",
    "@dcloudio/uni-app-harmony": "3.0.0-5000720260410001",
    "@dcloudio/uni-app-plus": "3.0.0-5000720260410001",
    "@dcloudio/uni-components": "3.0.0-5000720260410001",
    "@dcloudio/uni-h5": "3.0.0-5000720260410001",
    "@dcloudio/uni-mp-weixin": "3.0.0-5000720260410001",
    "dayjs": "^1.11.20",
    "luch-request": "^3.1.1",
    "pinia": "2.1.7",
    "vue": "3.4.21",
    "wot-design-uni": "^1.5.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@dcloudio/types": "3.4.28",
    "@dcloudio/uni-automator": "3.0.0-5000720260410001",
    "@dcloudio/uni-cli-shared": "3.0.0-5000720260410001",
    "@dcloudio/uni-stacktracey": "3.0.0-5000720260410001",
    "@dcloudio/vite-plugin-uni": "3.0.0-5000720260410001",
    "@pinia/testing": "^0.1.7",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/runtime-core": "3.4.21",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.1.3",
    "eslint": "^10.2.1",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "sass": "^1.77.0",
    "typescript": "~5.4.5",
    "vite": "5.2.8",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.0.0"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,scss,md}": [
      "prettier --write"
    ]
  }
}
