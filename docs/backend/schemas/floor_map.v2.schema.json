{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://propos.local/schemas/floor_map.v2.schema.json",
  "title": "PropOS Floor Map v2",
  "description": "楼层结构化语义 + 单元热区数据。由 scripts/split_dxf_by_floor.py 生成，由 Admin 标注页人工审核后通过 PUT /api/floors/:floorId/structures 写入。",
  "type": "object",
  "required": [
    "schema_version",
    "render_mode",
    "viewport"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0"
    },
    "render_mode": {
      "type": "string",
      "enum": ["vector", "semantic"]
    },
    "floor_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "building_id": {
      "type": ["string", "null"]
    },
    "floor_label": {
      "type": ["string", "null"]
    },
    "svg_version": {
      "type": ["string", "null"]
    },
    "viewport": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": false,
      "properties": {
        "width":  { "type": "integer", "minimum": 100, "maximum": 4000 },
        "height": { "type": "integer", "minimum": 100, "maximum": 4000 }
      }
    },
    "dxf_region": {
      "type": ["object", "null"],
      "required": ["min_x", "min_y", "max_x", "max_y"],
      "additionalProperties": false,
      "properties": {
        "min_x": { "type": "number" },
        "min_y": { "type": "number" },
        "max_x": { "type": "number" },
        "max_y": { "type": "number" }
      }
    },
    "outline": {
      "$ref": "#/$defs/Outline"
    },
    "structures": {
      "type": "array",
      "maxItems": 200,
      "items": { "$ref": "#/$defs/StructureOrColumn" }
    },
    "windows": {
      "type": "array",
      "maxItems": 100,
      "items": { "$ref": "#/$defs/Window" }
    },
    "north": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/NorthArrow" }
      ]
    },
    "units": {
      "type": "array",
      "items": { "$ref": "#/$defs/Unit" }
    }
  },
  "allOf": [
    {
      "description": "render_mode=semantic 必须包含完整的 outline 和至少一项结构",
      "if": { "properties": { "render_mode": { "const": "semantic" } } },
      "then": {
        "required": ["outline", "structures"],
        "properties": {
          "outline": { "type": "object" },
          "structures": { "type": "array", "minItems": 1 }
        }
      }
    }
  ],
  "$defs": {
    "Rect": {
      "type": "object",
      "required": ["x", "y", "w", "h"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "w": { "type": "integer", "minimum": 1 },
        "h": { "type": "integer", "minimum": 1 }
      }
    },
    "PointArray": {
      "type": "array",
      "minItems": 3,
      "maxItems": 32,
      "items": {
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "items": { "type": "integer", "minimum": 0 }
      }
    },
    "Outline": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["rect", "polygon"] },
        "rect": { "$ref": "#/$defs/Rect" },
        "points": { "$ref": "#/$defs/PointArray" }
      },
      "oneOf": [
        {
          "properties": { "type": { "const": "rect" } },
          "required": ["rect"]
        },
        {
          "properties": { "type": { "const": "polygon" } },
          "required": ["points"]
        }
      ]
    },
    "SourceTag": {
      "type": "string",
      "enum": ["auto", "manual"]
    },
    "StructureType": {
      "type": "string",
      "enum": ["core", "elevator", "stair", "restroom", "equipment", "corridor"]
    },
    "Structure": {
      "type": "object",
      "required": ["type", "rect", "source"],
      "additionalProperties": false,
      "properties": {
        "type": { "$ref": "#/$defs/StructureType" },
        "rect": { "$ref": "#/$defs/Rect" },
        "label": { "type": ["string", "null"], "maxLength": 32 },
        "code":  { "type": ["string", "null"], "pattern": "^[A-Z]\\d{1,3}$" },
        "gender": { "type": ["string", "null"], "enum": ["M", "F", "unknown", null] },
        "source": { "$ref": "#/$defs/SourceTag" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "elevator" } } },
          "then": { "required": ["code"] }
        },
        {
          "if": { "properties": { "type": { "const": "restroom" } } },
          "then": { "required": ["gender"] }
        }
      ]
    },
    "Column": {
      "type": "object",
      "required": ["type", "point", "source"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "column" },
        "point": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "integer", "minimum": 0 }
        },
        "source": { "$ref": "#/$defs/SourceTag" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "StructureOrColumn": {
      "oneOf": [
        { "$ref": "#/$defs/Structure" },
        { "$ref": "#/$defs/Column" }
      ]
    },
    "Window": {
      "type": "object",
      "required": ["side", "offset", "width"],
      "additionalProperties": false,
      "properties": {
        "side":   { "type": "string", "enum": ["N", "S", "E", "W"] },
        "offset": { "type": "integer", "minimum": 0 },
        "width":  { "type": "integer", "minimum": 8 }
      }
    },
    "NorthArrow": {
      "type": "object",
      "required": ["x", "y"],
      "additionalProperties": false,
      "properties": {
        "x":            { "type": "integer", "minimum": 0 },
        "y":            { "type": "integer", "minimum": 0 },
        "rotation_deg": { "type": "number",  "minimum": -180, "maximum": 180 }
      }
    },
    "Unit": {
      "type": "object",
      "required": ["unit_id", "label", "polygon"],
      "additionalProperties": false,
      "properties": {
        "unit_id":  { "type": "string", "format": "uuid" },
        "label":    { "type": "string", "maxLength": 32 },
        "polygon":  { "$ref": "#/$defs/PointArray" },
        "centroid": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "integer", "minimum": 0 }
        },
        "area_sqm": { "type": "number", "minimum": 0 },
        "property_type": {
          "type": "string",
          "enum": ["office", "retail", "apartment"]
        }
      }
    }
  }
}
