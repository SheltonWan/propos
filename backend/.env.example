# PropOS Backend 环境变量示例
# 复制此文件为 .env 并填写实际值
# 警告：.env 已加入 .gitignore，禁止提交到版本控制

# PostgreSQL 连接串
DATABASE_URL=postgres://propos:propos_dev_pwd@localhost:5432/propos_dev
# SSL 模式：disable（本地/容器内网）/ require（云数据库）
DB_SSL_MODE=disable

# JWT 配置（secret 最少 32 字节，建议 openssl rand -base64 48 生成）
JWT_SECRET=change-this-to-a-random-32-plus-byte-secret-key
JWT_EXPIRES_IN_HOURS=24

# 文件存储根目录
FILE_STORAGE_PATH=.local/uploads

# AES-256 加密密钥（32 字节 hex 字符串，64 hex chars，建议 openssl rand -hex 32 生成）
ENCRYPTION_KEY=0102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f20

# HTTP 端口
APP_PORT=8080

# SMTP 邮件服务（可选，留空则使用开发模式：仅打印日志，不实际发送）
# 端口 465 → 隐式 SSL；端口 587 → STARTTLS
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=change-this-smtp-password
SMTP_FROM=no-reply@example.com

# 可选配置
# CORS 跨域白名单（逗号分隔，精确匹配请求 Origin）
# 留空或不设置 → 不发任何 CORS 头（纯移动端 API 推荐）
# 设置为 * → 允许所有来源（仅限公开只读 API，慎用）
# 本地开发：Admin Vite dev server(5173) + uni-app H5 dev server(3000)
# 生产示例：CORS_ORIGINS=https://admin.propos.example,https://app.propos.example
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=debug
MAX_UPLOAD_SIZE_MB=50

# 开放集成测试辅助端点（仅限本地开发/CI，生产环境绝对不能设为 true）
ALLOW_TEST_ENDPOINTS=false
