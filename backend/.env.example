# PropOS Backend 环境变量示例
# 复制此文件为 .env 并填写实际值
# 警告：.env 已加入 .gitignore，禁止提交到版本控制

# PostgreSQL 连接串
DATABASE_URL=postgres://propos:propos_dev_pwd@localhost:5432/propos_dev

# JWT 配置（secret 最少 32 字节）
JWT_SECRET=change-this-to-a-random-32-plus-byte-secret-key
JWT_EXPIRES_IN_HOURS=24

# 文件存储根目录
FILE_STORAGE_PATH=/tmp/propos_storage

# AES-256 加密密钥（32 字节 hex 字符串，64 hex chars）
ENCRYPTION_KEY=0102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f20

# HTTP 端口
APP_PORT=8080

# 可选配置
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=debug
MAX_UPLOAD_SIZE_MB=50
